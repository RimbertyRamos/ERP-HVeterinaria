# URL de conexión a la base de datos PostgreSQL
# Local:    postgresql://USUARIO:PASSWORD@localhost:5432/erp_veterinaria
# Render:   postgresql://USUARIO:PASSWORD@HOST.render.com/DB?sslmode=require
DATABASE_URL=

# Entorno de ejecución (development, production)
NODE_ENV=development

# Puerto en el que corre el servidor backend (por defecto 4000 si no se define)
PORT=4000

# Secreto para firmar los JSON Web Tokens (JWT). Usar una cadena larga y aleatoria.
JWT_SECRET=

# API Key de OpenAI para el chatbot de asistencia VET-AI (solo en el backend).
# Se obtiene en https://platform.openai.com/api-keys (empieza con "sk-...").
# Si se deja vacía, el asistente responde con guías de primeros auxilios.
OPENAI_API_KEY=

# Correo (Nodemailer + Gmail SMTP) para confirmaciones de cita.
# Usa una "App Password" de Google (requiere verificación en 2 pasos):
# https://myaccount.google.com/apppasswords  -> pega los 16 caracteres en SMTP_PASS.
# Si se dejan vacías, el sistema funciona igual y solo registra el correo en consola.
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=
MAIL_FROM=Hospital Veterinario <tu-correo@gmail.com>

# Pago de planes (Stripe, modo PRUEBA) para la landing. Secret key (sk_test_...).
# https://dashboard.stripe.com/test/apikeys . Si se deja vacía, el botón de plan
# cae a captura de lead (sin cobro).
STRIPE_SECRET_KEY=
# URL del frontend para las redirecciones de pago (éxito/cancelado)
FRONTEND_URL=http://localhost:5173

# Orígenes permitidos para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:5173
