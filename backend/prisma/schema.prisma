generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// USUARIOS Y ROLES
// ===========================

model Role {
  id       String        @id @default(uuid())
  nombre   String        @unique
  usuarios Usuario[]
  permisos RolePermiso[]
}

// Catálogo de permisos del sistema (uno por acción/CU: gestionar_usuarios,
// gestionar_caja, registrar_historia_clinica, …). Reemplaza al antiguo
// Role.permisos Json? por un RBAC normalizado (1FN).
model Permiso {
  id          String        @id @default(uuid())
  codigo      String        @unique
  descripcion String?
  roles       RolePermiso[]
}

// Tabla intermedia N–M Role↔Permiso. Al borrar un rol se eliminan sus
// asignaciones (onDelete: Cascade en el lado Role).
model RolePermiso {
  role_id    String
  permiso_id String
  role       Role    @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permiso    Permiso @relation(fields: [permiso_id], references: [id])

  @@id([role_id, permiso_id])
}

model Usuario {
  id            String   @id @default(uuid())
  nombre        String
  email         String   @unique
  password_hash String
  telefono      String?
  ci            String?
  rol_id        String
  rol           Role     @relation(fields: [rol_id], references: [id])
  created_at    DateTime @default(now())

  debe_cambiar_password Boolean @default(false)
  activo                Boolean @default(true)

  mascotas           Mascota[]
  fichas_como_doctor FichaAtencion[] @relation("FichaDoctorRelation")
  fichas_creadas     FichaAtencion[] @relation("FichaCreadorRelation")
  recibos            ReciboCaja[]
  cierres_caja       CierreCaja[]
  citas              Cita[]
  salas_responsable  Consultorio[]   @relation("ResponsableSala")

  historias_atendidas   HistoriaClinica[] @relation("HistoriaMedico")
  historias_creadas     HistoriaClinica[] @relation("HistoriaCreadaPor")
  historias_finalizadas HistoriaClinica[] @relation("HistoriaFinalizadaPor")

  calificaciones Calificacion[]
  notificaciones Notificacion[]
  bitacoras      Bitacora[]
  horarios       HorarioConsultorio[] @relation("HorarioDoctor")
}

// ===========================
// CATÁLOGOS BASE
// ===========================

model Especie {
  id       String    @id @default(uuid())
  nombre   String    @unique
  razas    Raza[]
  mascotas Mascota[]
}

model Raza {
  id         String    @id @default(uuid())
  nombre     String
  especie_id String
  especie    Especie   @relation(fields: [especie_id], references: [id])
  mascotas   Mascota[]

  @@unique([nombre, especie_id])
}

model ColorMascota {
  id          String    @id @default(uuid())
  descripcion String    @unique
  mascotas    Mascota[]
}

model Alergia {
  id        String            @id @default(uuid())
  nombre    String            @unique
  pacientes PacienteAlergia[]
}

model CatalogoServicio {
  id          String          @id @default(uuid())
  nombre      String          @unique
  precio_base Decimal
  activo      Boolean         @default(true)
  fichas      FichaAtencion[]
  realizados  FichaServicio[]
}

// ===========================
// PACIENTES
// ===========================

model Mascota {
  id               String        @id @default(uuid())
  nombre           String
  especie_id       String
  especie          Especie       @relation(fields: [especie_id], references: [id])
  raza_id          String?
  raza             Raza?         @relation(fields: [raza_id], references: [id])
  color_id         String?
  color            ColorMascota? @relation(fields: [color_id], references: [id])
  fecha_nacimiento DateTime?
  sexo             String?       @db.Char(1)
  peso_actual      Decimal?
  esterilizado     Boolean       @default(false)
  propietario_id   String
  propietario      Usuario       @relation(fields: [propietario_id], references: [id])
  created_at       DateTime      @default(now())

  alergias  PacienteAlergia[]
  fichas    FichaAtencion[]
  citas     Cita[]
  historias HistoriaClinica[]
}

model PacienteAlergia {
  mascota_id String
  alergia_id String
  severidad  String
  mascota    Mascota @relation(fields: [mascota_id], references: [id], onDelete: Cascade)
  alergia    Alergia @relation(fields: [alergia_id], references: [id])

  @@id([mascota_id, alergia_id])
}

// ===========================
// CONSULTORIOS
// ===========================

model Consultorio {
  id             String               @id @default(uuid())
  nombre         String
  especialidad   String?
  tipo           TipoSala             @default(CONSULTORIO)
  estado         ConsultorioEstado    @default(LIBRE)
  responsable_id String?
  responsable    Usuario?             @relation("ResponsableSala", fields: [responsable_id], references: [id])
  fichas         FichaAtencion[]
  citas          Cita[]
  horarios       HorarioConsultorio[]
}

enum TipoSala {
  CONSULTORIO
  LABORATORIO
  QUIROFANO
  SALA_ESPERA
  OTRO
}

enum ConsultorioEstado {
  LIBRE
  OCUPADO
  LIMPIEZA
}

// ===========================
// FICHAS DE ATENCIÓN
// ===========================

model FichaAtencion {
  id             String           @id @default(uuid())
  cod_ficha      String           @unique
  mascota_id     String
  mascota        Mascota          @relation(fields: [mascota_id], references: [id])
  doctor_id      String?
  doctor         Usuario?         @relation("FichaDoctorRelation", fields: [doctor_id], references: [id])
  consultorio_id String?
  consultorio    Consultorio?     @relation(fields: [consultorio_id], references: [id])
  servicio_id    String
  servicio       CatalogoServicio @relation(fields: [servicio_id], references: [id])
  creado_por_id  String?
  creado_por     Usuario?         @relation("FichaCreadorRelation", fields: [creado_por_id], references: [id])
  motivo         String?
  estado         EstadoFicha      @default(ESPERA)
  prioridad      Prioridad        @default(NORMAL)
  estado_cobro   EstadoCobro      @default(PENDIENTE)
  fecha_hora     DateTime         @default(now())

  soap                 RegistroSOAP?
  consumos             ConsumoConsulta[]
  servicios_realizados FichaServicio[]
  recibo               ReciboCaja?
  historia             HistoriaClinica?
  calificacion         Calificacion?
}

model Cita {
  id                   String       @id @default(uuid())
  mascota_id           String
  mascota              Mascota      @relation(fields: [mascota_id], references: [id])
  doctor_id            String?
  doctor               Usuario?     @relation(fields: [doctor_id], references: [id])
  consultorio_id       String?
  consultorio          Consultorio? @relation(fields: [consultorio_id], references: [id])
  fecha_hora           DateTime
  duracion_min         Int          @default(30)
  tipo                 TipoCita     @default(CONSULTA)
  motivo               String
  notas                String?
  estado               EstadoCita   @default(PROGRAMADA)
  recordatorio_enviado Boolean      @default(false)
  created_at           DateTime     @default(now())
}

enum EstadoCita {
  SOLICITADA
  PROGRAMADA
  CONFIRMADA
  COMPLETADA
  CANCELADA
  NO_ASISTIO
}

enum TipoCita {
  CONSULTA
  CONTROL
  VACUNACION
  CIRUGIA
  PELUQUERIA
  OTRO
}

enum EstadoFicha {
  ESPERA
  EN_CURSO
  COMPLETADA
  CANCELADA
}

enum Prioridad {
  URGENTE
  NORMAL
}

enum EstadoCobro {
  PENDIENTE
  PAGADO
  EXENTO
}

// ===========================
// REGISTRO SOAP
// ===========================

model RegistroSOAP {
  id             String        @id @default(uuid())
  ficha_id       String        @unique
  ficha          FichaAtencion @relation(fields: [ficha_id], references: [id], onDelete: Cascade)
  motivo_detalle String?
  anamnesis      String?
  peso           Decimal?
  temperatura    Decimal?
  fc             Int?
  fr             Int?
  hallazgos      String?
  diagnostico    String?
  tratamiento    String?
  created_at     DateTime      @default(now())
}

// ===========================
// PRODUCTOS E INVENTARIO
// ===========================

model CategoriaProducto {
  id        String       @id @default(uuid())
  nombre    String       @unique
  tipo_item TipoProducto @default(MEDICAMENTO)
  productos Producto[]
}

enum TipoProducto {
  MEDICAMENTO
  INSUMO_MEDICO
  VACUNA
  ALIMENTO
}

model Producto {
  id           String             @id @default(uuid())
  nombre       String
  descripcion  String?
  categoria_id String?
  categoria    CategoriaProducto? @relation(fields: [categoria_id], references: [id])
  precio_venta Decimal
  stock_actual Int                @default(0)
  stock_minimo Int                @default(5)

  kardex         KardexMovimiento[]
  detalles_cobro DetalleCobro[]
  consumos       ConsumoConsulta[]
}

// ===========================
// CONSUMOS EN CONSULTA
// ===========================

model ConsumoConsulta {
  id          String        @id @default(uuid())
  ficha_id    String
  ficha       FichaAtencion @relation(fields: [ficha_id], references: [id], onDelete: Cascade)
  producto_id String
  producto    Producto      @relation(fields: [producto_id], references: [id])
  cantidad    Int
  created_at  DateTime      @default(now())
}

// Servicios realizados durante la consulta (seleccionados por el veterinario).
// El precio se "congela" al momento de agregarlo, para no alterar cobros previos
// si luego cambia la tarifa del catálogo.
model FichaServicio {
  id          String           @id @default(uuid())
  ficha_id    String
  ficha       FichaAtencion    @relation(fields: [ficha_id], references: [id], onDelete: Cascade)
  servicio_id String
  servicio    CatalogoServicio @relation(fields: [servicio_id], references: [id])
  precio      Decimal
  cantidad    Int              @default(1)
  created_at  DateTime         @default(now())
}

// ===========================
// PROVEEDORES Y STOCK
// ===========================

model KardexMovimiento {
  id          String         @id @default(uuid())
  producto_id String
  producto    Producto       @relation(fields: [producto_id], references: [id])
  tipo        TipoMovimiento
  cantidad    Int
  saldo_final Int
  motivo      String?
  created_at  DateTime       @default(now())
}

enum TipoMovimiento {
  INGRESO
  SALIDA
}

// ===========================
// CAJA Y FACTURACIÓN
// ===========================

model PuntoCaja {
  id        String       @id @default(uuid())
  nombre    String       @unique
  ubicacion String?
  recibos   ReciboCaja[]
}

model ReciboCaja {
  id               String         @id @default(uuid())
  num_recibo       String         @unique
  ficha_id         String?        @unique
  ficha            FichaAtencion? @relation(fields: [ficha_id], references: [id])
  cajero_id        String
  cajero           Usuario        @relation(fields: [cajero_id], references: [id])
  nombre_cliente   String? // Para ventas directas sin ficha
  punto_caja_id    String?
  punto_caja       PuntoCaja?     @relation(fields: [punto_caja_id], references: [id])
  total            Decimal
  descuento        Decimal        @default(0)
  tipo_descuento   TipoDescuento?
  metodo_pago      MetodoPago     @default(EFECTIVO)
  monto_recibido   Decimal?
  cambio_devuelto  Decimal?
  estado           EstadoRecibo   @default(EMITIDO)
  motivo_anulacion String?
  fecha_pago       DateTime       @default(now())

  detalles DetalleCobro[]
}

model CierreCaja {
  id               String   @id @default(uuid())
  cajero_id        String
  cajero           Usuario  @relation(fields: [cajero_id], references: [id])
  fecha_desde      DateTime
  fecha_hasta      DateTime
  total_efectivo   Decimal  @default(0)
  total_tarjeta    Decimal  @default(0)
  total_qr         Decimal  @default(0)
  total_general    Decimal  @default(0)
  cantidad_recibos Int      @default(0)
  efectivo_contado Decimal?
  diferencia       Decimal?
  observaciones    String?
  created_at       DateTime @default(now())
}

// ── Landing pública: leads de contacto y suscripciones (pago) ────────────────
model Lead {
  id         String     @id @default(uuid())
  nombre     String
  email      String
  telefono   String?
  empresa    String?
  mensaje    String?
  origen     OrigenLead @default(CONTACTO)
  created_at DateTime   @default(now())
}

model Suscripcion {
  id                  String            @id @default(uuid())
  plan                String
  nombre              String?
  email               String?
  monto               Decimal           @default(0)
  moneda              String            @default("usd")
  estado              EstadoSuscripcion @default(PENDIENTE)
  stripe_session_id   String?           @unique
  cuenta_provisionada Boolean           @default(false)
  usuario_id          String?
  created_at          DateTime          @default(now())
}

enum OrigenLead {
  CONTACTO
  DEMO
  PLAN
  NEWSLETTER
}

enum EstadoSuscripcion {
  PENDIENTE
  PAGADO
  CANCELADO
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  QR
}

enum TipoDescuento {
  PORCENTAJE
  MONTO
}

enum EstadoRecibo {
  EMITIDO
  PAGADO
  ANULADO
}

model DetalleCobro {
  id          String           @id @default(uuid())
  recibo_id   String
  recibo      ReciboCaja       @relation(fields: [recibo_id], references: [id], onDelete: Cascade)
  tipo        TipoDetalleCobro
  descripcion String
  precio_unit Decimal
  cantidad    Int              @default(1)
  subtotal    Decimal
  producto_id String?
  producto    Producto?        @relation(fields: [producto_id], references: [id])
}

enum TipoDetalleCobro {
  SERVICIO
  FARMACIA
  SUMINISTRO
}

// ===========================
// HISTORIA CLÍNICA (ficha de consulta externa)
// ===========================

enum EstadoHistoria {
  BORRADOR
  FINALIZADA
}

model HistoriaClinica {
  id    String   @id @default(uuid())
  folio Int      @unique @default(autoincrement())
  fecha DateTime @default(now())

  mascota_id      String
  mascota         Mascota        @relation(fields: [mascota_id], references: [id])
  ficha_id        String?        @unique
  ficha           FichaAtencion? @relation(fields: [ficha_id], references: [id])
  atendido_por_id String?
  atendido_por    Usuario?       @relation("HistoriaMedico", fields: [atendido_por_id], references: [id])

  // Snapshot del propietario (la ficha de papel pide estos datos)
  propietario_nombre String?
  domicilio          String?
  telefono           String?
  celular            String?

  // Datos del paciente para ESTA consulta (cambian con el tiempo)
  edad String?
  peso Decimal?

  // Anamnesis
  motivo_consulta        String?
  vacunas_otras          String? // texto libre para vacunas no catalogadas
  desparasitacion        Boolean @default(false)
  desparasitacion_cuando String?
  enfermedades_previas   String?
  intervenciones_previas String?

  // Examen físico
  estado_general           String?
  apetito                  String?
  hidratacion              String?
  mucosa                   String?
  ap_digestivo             String?
  ap_genitourinario        String?
  ap_respiratorio          String?
  temperatura              Decimal?
  fc                       Int?
  fr                       Int?
  observacion_clinica      String?
  pruebas_complementarias  String?
  diagnostico_presuntivo   String?
  diagnostico_confirmativo String?
  pronostico               String?
  tratamiento              String?

  estado EstadoHistoria @default(BORRADOR)

  // Auditoría
  created_by_id   String?
  created_by      Usuario?  @relation("HistoriaCreadaPor", fields: [created_by_id], references: [id])
  created_at      DateTime  @default(now())
  finalized_by_id String?
  finalized_by    Usuario?  @relation("HistoriaFinalizadaPor", fields: [finalized_by_id], references: [id])
  finalized_at    DateTime?
  updated_at      DateTime  @updatedAt

  evoluciones EvolucionTratamiento[]
  vacunas     HistoriaVacuna[]
}

model EvolucionTratamiento {
  id          String          @id @default(uuid())
  historia_id String
  historia    HistoriaClinica @relation(fields: [historia_id], references: [id], onDelete: Cascade)
  fecha       DateTime        @default(now())
  descripcion String
}

// Catálogo de vacunas (reemplaza al antiguo HistoriaClinica.vacunas String[]).
model Vacuna {
  id        String           @id @default(uuid())
  nombre    String           @unique
  historias HistoriaVacuna[]
}

// Tabla intermedia N–M HistoriaClinica↔Vacuna. Al borrar la historia se eliminan
// sus filas de vacuna aplicada (onDelete: Cascade en el lado historia).
model HistoriaVacuna {
  historia_id          String
  vacuna_id            String
  fecha_aplicacion     DateTime?
  // RF14: fecha de próxima dosis (la fija el veterinario) y bandera para no
  // duplicar el recordatorio de vencimiento.
  proxima_dosis        DateTime?
  recordatorio_enviado Boolean         @default(false)
  historia             HistoriaClinica @relation(fields: [historia_id], references: [id], onDelete: Cascade)
  vacuna               Vacuna          @relation(fields: [vacuna_id], references: [id])

  @@id([historia_id, vacuna_id])
}

// ===========================
// CALIFICACIÓN DE SERVICIO (CU20)
// ===========================
// El propietario califica la atención recibida. Relación 1–1 con la ficha
// (ficha_id @unique): una ficha se califica una sola vez.
model Calificacion {
  id             String        @id @default(uuid())
  ficha_id       String        @unique
  ficha          FichaAtencion @relation(fields: [ficha_id], references: [id], onDelete: Cascade)
  propietario_id String
  propietario    Usuario       @relation(fields: [propietario_id], references: [id])
  puntaje        Int
  comentario     String?
  fecha          DateTime      @default(now())
}

// ===========================
// NOTIFICACIONES (in-app)
// ===========================
enum TipoNotificacion {
  CITA
  RECORDATORIO
  SISTEMA
}

// Notificación in-app del usuario. Complementa (no reemplaza) los correos:
// p. ej. el recordatorio de cita persiste aquí además de enviarse por email.
model Notificacion {
  id          String           @id @default(uuid())
  usuario_id  String
  usuario     Usuario          @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  tipo        TipoNotificacion
  titulo      String
  mensaje     String
  leida       Boolean          @default(false)
  fecha_envio DateTime         @default(now())
}

// ===========================
// BITÁCORA (auditoría del sistema — realiza "EventoSistema")
// ===========================
enum AccionBitacora {
  LOGIN
  LOGOUT
  LOGIN_FALLIDO
  CAMBIO_PASSWORD
  CREAR
  ACTUALIZAR
  ELIMINAR
  CAMBIO_ESTADO
  CAMBIO_ROL
  APLICAR_DESCUENTO
  ANULAR
  CIERRE_CAJA
  EXPORTAR
  ACCESO_HISTORIA
}

// Registro de auditoría. Los campos actor_* son SNAPSHOTS: preservan quién hizo
// la acción aunque luego se borre el Usuario (usuario_id queda en null por
// onDelete: SetNull). Los snapshots datos_antes/despues guardan JSON serializado
// (String, no Json nativo) con los secretos ya redactados.
model Bitacora {
  id         String   @id @default(uuid())
  fecha_hora DateTime @default(now())

  usuario_id   String?
  usuario      Usuario? @relation(fields: [usuario_id], references: [id], onDelete: SetNull)
  actor_email  String?
  actor_nombre String?
  actor_rol    String?

  accion      AccionBitacora
  entidad     String?
  entidad_id  String?
  descripcion String

  datos_antes   String?
  datos_despues String?

  exito       Boolean @default(true)
  ip          String?
  user_agent  String?
  metodo_http String?
  ruta        String?

  @@index([fecha_hora])
  @@index([usuario_id])
  @@index([entidad, entidad_id])
  @@index([accion])
}

// ===========================
// PROGRAMACIÓN HORARIA (asignación de doctor a consultorio por franjas)
// ===========================
// Franja de disponibilidad: un doctor asignado a un consultorio entre [inicio, fin).
// La validación de solapamiento (misma sala o mismo doctor a la vez) vive en
// HorarioService, no en la BD.
model HorarioConsultorio {
  id             String      @id @default(uuid())
  consultorio_id String
  consultorio    Consultorio @relation(fields: [consultorio_id], references: [id], onDelete: Cascade)
  doctor_id      String
  doctor         Usuario     @relation("HorarioDoctor", fields: [doctor_id], references: [id])
  inicio         DateTime
  fin            DateTime
  nota           String?
  created_at     DateTime    @default(now())

  @@index([consultorio_id, inicio])
  @@index([doctor_id, inicio])
}
